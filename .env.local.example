# Sanity CMS Configuration
# These are required for the CMS to work. Get them from https://sanity.io/manage

# Public variables (safe to expose to browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Private variables (server-only, never expose to browser)
# Only needed for seed script or preview/draft mode
# NOT required for normal public website operation

# SANITY_API_WRITE_TOKEN - Required for seeding initial data
# To create a write token:
# 1. Go to https://sanity.io/manage
# 2. Select your project
# 3. Go to API → Tokens
# 4. Click "Add API token"
# 5. Name: "Seed Script Write Token"
# 6. Permissions: "Editor"
# 7. Copy the token and paste below:
SANITY_API_WRITE_TOKEN=your_write_token_here